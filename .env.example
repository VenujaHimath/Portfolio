# Contact form — Resend (recommended on Vercel)
# 1. Create key: https://resend.com/api-keys
# 2. Add all three in Vercel → Project → Settings → Environment Variables (Production)
# 3. Redeploy after saving

RESEND_API_KEY=re_paste_your_real_key_here
CONTACT_TO_EMAIL=venuja.ranasinghe1977@gmail.com
EMAIL_FROM=Portfolio <onboarding@resend.dev>

# Resend test mode: with onboarding@resend.dev you can only deliver to the
# email address on your Resend account until you verify a custom domain.

# Option B: SMTP (Gmail app password) — use instead of RESEND_API_KEY
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=venuja.ranasinghe1977@gmail.com
# SMTP_PASS=your_16_char_app_password
# CONTACT_TO_EMAIL=venuja.ranasinghe1977@gmail.com
# EMAIL_FROM=Portfolio <venuja.ranasinghe1977@gmail.com>
